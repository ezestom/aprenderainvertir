---
import sun from "../icons/sun.svg";
import moon from "../icons/moon.svg";
---

<button
	id="themeToggle"
	class="transition-colors group w-full flex items-center justify-start gap-2 hover:bg-[--darkblue] py-2 px-3 rounded-md">
	<span
		class="relative group-hover:rotate-45 group-hover:scale-110 transition duration-300 drop-shadow-md flex">
		<img
			id="sunIcon"
			src={sun.src}
			class="sun w-5 transition-all"
			alt="Sol"
		/>
		<img
			id="moonIcon"
			src={moon.src}
			class="moon w-5 transition-all"
			alt="Luna"
		/>
	</span>
	<span
		id="themeText"
		class="whitespace-nowrap font-semibold transition-colors text-sm group-hover:text-[--lightblue]">
		Ir a Modo Oscuro
	</span>
</button>

<style>
	:root {
		transition:
			background-color 0.5s ease,
			color 0.5s ease;
	}

	html.dark {
		transition:
			background-color 0.5s ease,
			color 0.5s ease;
	}
	.moon {
		display: none;
	}
	:global(.dark) .sun {
		display: none;
	}
	:global(.dark) .moon {
		display: inline-block;
	}

	/* Transición suave al cambiar de tema */
	:root {
		transition:
			background-color 0.5s ease,
			color 0.5s ease;
	}
	html.dark {
		transition:
			background-color 0.5s ease,
			color 0.5s ease;
	}
</style>

<script is:inline>
	const setupThemeToggle = () => {
		const savedTheme = localStorage.getItem("theme");
		const prefersDarkScheme = window.matchMedia(
			"(prefers-color-scheme: dark)"
		).matches;
		const isDark = savedTheme === "dark" || (!savedTheme && prefersDarkScheme);
		
		document.documentElement.classList.toggle("dark", isDark);

		const themeText = document.getElementById("themeText");
		if (themeText) {
			themeText.innerText = isDark ? "Ir a Modo Claro" : "Ir a Modo Oscuro";
		}

		const themeToggleButton = document.getElementById("themeToggle");
		if (themeToggleButton && !themeToggleButton.dataset.hasListener) {
			themeToggleButton.dataset.hasListener = "true";
			themeToggleButton.addEventListener("click", () => {
				const element = document.documentElement;
				const isCurrentlyDark = element.classList.toggle("dark");
				localStorage.setItem("theme", isCurrentlyDark ? "dark" : "light");
				
				if (themeText) {
					themeText.innerText = isCurrentlyDark ? "Ir a Modo Claro" : "Ir a Modo Oscuro";
				}
			});
		}
	};

	// Ejecutar inmediatamente en carga inicial
	setupThemeToggle();

	// Ejecutar tras transiciones de Astro
	document.addEventListener("astro:page-load", setupThemeToggle);
</script>
