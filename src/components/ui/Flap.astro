---
import logo from "../../icons/e_logo_op_2.png";
---

<div
  class="pointer-events-none fixed bottom-0 right-0 z-100 origin-bottom-right scale-75 bg-transparent bg-[url('https://storage.googleapis.com/candycode/bg.png')] bg-[length:100%_100%] bg-no-repeat pl-[256px] pt-[96px] leading-none sm:scale-100 z-50"
>
  <a
    href="https://ezestom.is-a.dev/"
    target="_blank"
    rel="noopener noreferrer"
    class="transition pointer-events-auto relative inline-flex w-full flex-col items-center justify-center p-[16px] text-xs text-center text-white/75 leading-3 group"
  >
    Created & <br />
    designed by
    <br />
    <img src={logo.src} alt="logo" class="w-6 mt-2" />
  </a>
</div>
